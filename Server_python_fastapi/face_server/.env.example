# ===========================================================================
# .env.example — Plantilla de configuración del servidor FastAPI EMBEBIDOS_1
# ---------------------------------------------------------------------------
# Copia este archivo a `.env` y completa los valores. `.env` está en .gitignore
# (NUNCA se commitea). NO pongas secretos reales en este .example.
# Todas las variables tienen default en config.py: puedes dejar vacías las que
# no necesites en Fase 6.
# ===========================================================================

# --- Servidor HTTP ---
HOST=0.0.0.0
PORT=8000

# CORS: "*" abierto (red local). O lista separada por comas de orígenes.
CORS_ORIGINS=*

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Endurecimiento para despliegue en la nube (hardening) ---
# API_KEY: si la dejas VACÍA → modo dev (sin protección, no rompe nada).
# Si la defines, los endpoints sensibles (/verify, /enroll, DELETE /enroll/{name},
# /arm, /disarm, /fcm/register) exigen el header  X-API-Key: <valor>.
# Genérala con:  python -c "import secrets;print(secrets.token_urlsafe(32))"
API_KEY=

# Días de retención de fotos en storage/photos (privacidad + disco).
# Una tarea periódica borra las más antiguas que este umbral.
PHOTO_RETENTION_DAYS=7

# Cada cuántas horas corre la pasada de borrado de fotos antiguas.
PHOTO_CLEANUP_INTERVAL_HOURS=6

# --- Reconocimiento facial (se usa de verdad en Fase 7) ---
DEEPFACE_MODEL=ArcFace
DEEPFACE_DETECTOR=opencv
THRESHOLD=0.6

# --- Rutas de almacenamiento (opcional; por defecto bajo ./storage) ---
# STORAGE_DIR=
# PHOTOS_DIR=
# EMBEDDINGS_FILE=
# EVENTS_DB=
# FCM_TOKENS_FILE=
# STATE_FILE=

# --- Telegram (Fase 8) — obtener de @BotFather y getUpdates ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Firebase / FCM (Fase 9) — ruta al serviceAccountKey.json ---
FCM_CREDENTIALS_PATH=secrets/serviceAccountKey.json
